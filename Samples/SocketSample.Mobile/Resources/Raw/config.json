{
  "clientId": 1,
  "clientName": "sample-mobile-client",
  "host": "127.0.0.1",
  "port": 5000,
  "useControlServer": true,
  "receiveTimeoutSeconds": 10,
  "security": {
    "tlsProtocol": "Tls13",
    "requireTls13": true,
    "requireClientCertificate": false,
    "certificateDirectory": "",
    "certificatePasswordEnvironmentVariable": "SOCKET_CERTIFICATE_PASSWORD",
    "certificateRenewBeforeDays": 30,
    "rootCertificateLifetimeYears": 10,
    "moduleCertificateLifetimeYears": 2,
    "authenticationTimeoutMilliseconds": 5000
  }
}
